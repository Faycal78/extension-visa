{
  "manifest_version": 3,
  "name": "Visa OCR Local",
  "version": "0.2.0",
  "description": "OCR local dans Chrome relie a un backend Laravel local.",
  "permissions": ["activeTab", "tabs", "scripting"],
  "host_permissions": ["http://127.0.0.1:8000/*", "http://localhost:8000/*"],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'; connect-src 'self' http://127.0.0.1:8000 http://localhost:8000;"
  },
  "action": {
    "default_title": "Visa OCR Local",
    "default_popup": "panel.html"
  }
}
